/*
 * 조도센서 모듈(4핀) -> Max/MSP 귀신 사진 크로스페이드
 * 
 * ============ 배선 (4핀 모듈) ============
 * 
 *   조도센서 모듈       아두이노
 *   ────────────      ────────
 *     VCC          --> 5V
 *     GND          --> GND
 *     AO           --> A0 (아날로그 0번 핀)
 *     DO           --> (사용 안 함 - 연결 안 해도 됨)
 * 
 *   선 3개만 연결하면 끝!
 *   DO는 디지털 출력(밝다/어둡다 on/off)이라 여기선 안 씁니다.
 *   AO가 밝기를 0~1023 연속값으로 출력합니다.
 * 
 * ============ 동작 ============
 * 
 *   밝을 때: AO 값 높음 -> 뒤집어서 Max에 0 전송 (일반 사진)
 *   어두울 때: AO 값 낮음 -> 뒤집어서 Max에 255 전송 (귀신 사진)
 */

void setup()
{
  Serial.begin(9600);
}

void loop()
{
  int raw = analogRead(A0);

  // 뒤집기: 밝으면 0, 어두우면 255
  byte val = map(raw, 0, 1024, 255, 0);

  Serial.write(6);      // 주소 바이트 (조도센서 = 6)
  Serial.write(val);    // 값 바이트 (0=밝음, 255=어두움)

  delay(50);
}
